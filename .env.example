MUNIBOT_APP_NAME=Chatbot Core
MUNIBOT_ORGANIZATION_NAME=Example Organization
MUNIBOT_ORGANIZATION_TYPE=company
MUNIBOT_CITY_NAME=Example Organization
MUNIBOT_DOMAIN_PROFILE_PATH=profiles/company.json

MUNIBOT_PUBLIC_BASE_URL=http://localhost:8000
MUNIBOT_ALLOWED_ORIGINS_RAW=http://localhost:8000,http://127.0.0.1:8000

MUNIBOT_AI_BACKEND=lmstudio
MUNIBOT_LMSTUDIO_BASE_URL=http://127.0.0.1:1234
MUNIBOT_LMSTUDIO_CHAT_MODEL=gemma-4-26b-a4b-it-mlx
MUNIBOT_LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

MUNIBOT_OLLAMA_HOSTS_RAW=http://127.0.0.1:11434
MUNIBOT_OLLAMA_CHAT_MODEL=qwen3.5:9b
MUNIBOT_OLLAMA_EMBED_MODEL=bge-m3

MUNIBOT_CORPUS_DIR=data/corpus
MUNIBOT_ENABLE_SEMANTIC_RAG=true
MUNIBOT_ENABLE_ANSWER_VERIFICATION=true
MUNIBOT_TOP_K=5
MUNIBOT_MIN_GROUNDING_SCORE=0.18

MUNIBOT_APPOINTMENT_URL=https://example.com/appointments
MUNIBOT_INCIDENTS_URL=https://example.com/support/incidents
MUNIBOT_HUMAN_HANDOFF_URL=https://example.com/support/contact

MUNIBOT_EDGE_TTS_VOICE=en-US-AriaNeural
MUNIBOT_EDGE_TTS_RATE=+0%
MUNIBOT_WHISPER_MODEL_NAME=base
MUNIBOT_WHISPER_LANGUAGE=en
